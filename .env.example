# Server
PORT=5555
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nest_better_auth

# Better-Auth
BETTER_AUTH_URL=http://localhost:5555
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Cookie signing — REQUIRED in production
COOKIE_SECRET=change-me-to-a-random-secret-at-least-32-chars

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP (Mailpit for local dev: docker compose up)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@localhost
# SMTP_USER=   # leave blank for Mailpit (no auth)
# SMTP_PASS=
