# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
PORT=5555
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nest_better_auth

# ─────────────────────────────────────────────────────────────────────────────
# Better-Auth
# ─────────────────────────────────────────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:5555
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Cookie signing — REQUIRED in production
COOKIE_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ─────────────────────────────────────────────────────────────────────────────
# CORS + Callback URL allowlist
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed web origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Comma-separated list of custom URI schemes allowed as OAuth / password-reset
# callbackURL values (e.g. deep links in mobile apps). Leave blank for web-only.
# Example: ALLOWED_CALLBACK_SCHEMES=myapp,oauthapp
# ALLOWED_CALLBACK_SCHEMES=

# ─────────────────────────────────────────────────────────────────────────────
# Social Providers (optional — leave blank to disable)
# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth
# Callback URL to add in Google Cloud Console:
#   {BETTER_AUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Apple Sign-In (required by App Store when any other social login is offered)
# Callback URL to add in Apple Developer Console:
#   {BETTER_AUTH_URL}/api/auth/callback/apple
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# SMTP (Mailpit for local dev: docker compose up)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@localhost
# SMTP_USER=   # leave blank for Mailpit (no auth)
# SMTP_PASS=

# ─────────────────────────────────────────────────────────────────────────────
# Redis — used by session cache (N12) and email queue (N13)
# Omit to disable both features (falls back to in-memory cache, sync email)
# ─────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# File Storage (P17) — STORAGE_DRIVER selects the adapter
# Options: fs (default, dev) | minio | s3 | r2
# ─────────────────────────────────────────────────────────────────────────────
# STORAGE_DRIVER=fs

# MinIO — docker compose up minio (console: http://localhost:9001)
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=uploads
# MINIO_PUBLIC_URL=http://localhost:9000/uploads

# AWS S3
# AWS_REGION=us-east-1
# AWS_BUCKET=my-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PUBLIC_URL=https://my-bucket.s3.us-east-1.amazonaws.com

# Cloudflare R2 (uses same S3 adapter — just set the R2 endpoint)
# R2_ACCOUNT_ID=
# R2_BUCKET=my-bucket
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─────────────────────────────────────────────────────────────────────────────
# Observability (P14) — all optional; omit to disable each feature
# ─────────────────────────────────────────────────────────────────────────────
# APP_NAME=NestJS Better-Auth         # shown in email templates (P15)

# Prometheus: /metrics endpoint is always on when MetricsModule is loaded
# Scrape it from docker-compose.observability.yml → Prometheus service

# Loki log shipping — set LOKI_URL to ship Pino logs to Loki (OB4)
# docker compose -f docker-compose.yml -f docker-compose.observability.yml up -d loki
# LOKI_URL=http://localhost:3101

# OpenTelemetry tracing — set OTEL_ENABLED=true to activate (OB3)
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=nest-better-auth
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─────────────────────────────────────────────────────────────────────────────
# Feature flags — override any default in src/config/features.config.ts
# Omit a var to use the project default; set to false/0 to disable.
# ─────────────────────────────────────────────────────────────────────────────
# Infrastructure
# FEATURE_REDIS=true
# FEATURE_EMAIL_QUEUE=true

# Auth plugins
# FEATURE_TWO_FACTOR=true
# FEATURE_MAGIC_LINK=true
# FEATURE_ORGANIZATION=true
# FEATURE_SOCIAL_AUTH=true

# API surface
# FEATURE_SWAGGER=true           # set false in production for tighter surface area
# FEATURE_RATE_LIMITING=true
# FEATURE_AUDIT_LOG=true
# FEATURE_SCHEDULER=true
# FEATURE_EMAIL_PREVIEW=true     # dev only — always disabled in production

# Observability
# FEATURE_METRICS=true
# FEATURE_TRACING=false          # opt-in — heavy; also requires OTEL_ENABLED=true
# FEATURE_LOG_SHIPPING=false     # opt-in — requires LOKI_URL
